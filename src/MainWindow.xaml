<Window x:Class="PrMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PrMonitor.ViewModels"
        mc:Ignorable="d"
        Title="PR Monitor"
        Width="380" SizeToContent="Height"
        MaxHeight="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeChanged="Window_SizeChanged"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Shared styles -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrRow" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="{DynamicResource PrRowPadding}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <EventSetter Event="PreviewMouseRightButtonUp" Handler="PrRow_PreviewMouseRightButtonUp"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#21262D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RepoText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource PrRowRepoFontSize}"/>
            <Setter Property="Foreground" Value="#8B949E"/>
        </Style>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource PrRowFontSize}"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="MetaText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#6E7681"/>
        </Style>

        <!-- Minimal overlay scrollbar -->
        <Style x:Key="MinimalScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3" Background="#555E69" Margin="1,3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalScrollBar" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent" Width="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Height="0" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MinimalScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Height="0" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayScrollViewer" TargetType="ScrollViewer">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Margin="{TemplateBinding Padding}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Stretch"
                                       Style="{StaticResource MinimalScrollBar}"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_VerticalScrollBar"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_VerticalScrollBar"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrRowMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="0" Background="Transparent" SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrRowMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Margin="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              Margin="4,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#30363D"/>
                                <Setter Property="Foreground" Value="#F0F6FC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6E7681"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrRowContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="MenuItem" BasedOn="{StaticResource PrRowMenuItemStyle}"/>
                <Style TargetType="Separator" BasedOn="{StaticResource PrRowMenuSeparatorStyle}"/>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <!-- Outer border with rounded corners and shadow -->
    <Border x:Name="OuterBorder" Background="#0D1117" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.5" ShadowDepth="2" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="*"/>     <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Background="#161B22" CornerRadius="8,8,0,0" Padding="12,8">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <!-- Refresh button -->
                        <Border x:Name="RefreshButton" CornerRadius="4" Padding="5,3"
                                Cursor="Hand" ToolTip="Refresh now"
                                MouseLeftButtonUp="RefreshButton_Click"
                                Background="#21262D" Margin="0,0,4,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#30363D"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock x:Name="RefreshIcon"
                                       Text="&#xE72C;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="12"
                                       Foreground="#6E7681"
                                       VerticalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="RefreshRotate" Angle="0"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Border>
                        <!-- Close button -->
                        <Border CornerRadius="4"
                                Padding="5,3" Cursor="Hand" ToolTip="Close"
                                MouseLeftButtonUp="CloseButton_Click"
                                Background="#21262D">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#8B1A1A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="12"
                                       Foreground="#8B949E"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <!-- Drag handle: entire left area -->
                    <Border Background="Transparent" Cursor="SizeAll"
                            MouseLeftButtonDown="Header_MouseLeftButtonDown">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="PR Monitor" FontSize="14" FontWeight="Bold" Foreground="#E6EDF3"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock FontSize="11" Foreground="#6E7681" VerticalAlignment="Center"
                                       Text="{Binding LastUpdated, StringFormat='Updated {0}'}"
                                       Margin="0,0,8,0"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" Style="{StaticResource OverlayScrollViewer}" Padding="12,8">
                <StackPanel>

                    <!-- Section: Hotfixes (only visible when HotfixCount > 0) -->
                    <StackPanel Visibility="{Binding HotfixCount, Converter={StaticResource NonZeroToVisibleConverter}}">
                        <Border MouseLeftButtonUp="HotfixHeader_Click" Cursor="Hand"
                                Background="Transparent" Margin="0,0,0,6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                           FontSize="10" Foreground="#6E7681" VerticalAlignment="Center"
                                           Margin="0,0,6,0" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding HotfixExpanded,
                                            Converter={StaticResource BoolToAngleConverter}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE90F;" FontFamily="Segoe Fluent Icons"
                                               FontSize="12" Foreground="#F85149"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E6EDF3"
                                               VerticalAlignment="Center">
                                        <Run Text="Hotfixes "/>
                                        <Run Text="{Binding HotfixCount, StringFormat='({0})', Mode=OneWay}"
                                             Foreground="#8B949E"/>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <StackPanel Visibility="{Binding HotfixExpanded, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl ItemsSource="{Binding HotfixPrs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PrRow}"
                                                MouseLeftButtonUp="PrItem_Click"
                                                ToolTip="{Binding PrTooltip}"
                                                Tag="{Binding}">
                                            <Border.ContextMenu>
                                                <ContextMenu Style="{StaticResource PrRowContextMenuStyle}">
                                                    <MenuItem Header="Copy PR URL" Tag="{Binding}"
                                                              Click="PrRow_CopyUrl_Click"/>
                                                    <MenuItem Header="Copy branch name" Tag="{Binding}"
                                                              Click="PrRow_CopyBranch_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Rerun failed jobs" Tag="{Binding}"
                                                              Click="PrRow_RerunFailedJobs_Click"
                                                              IsEnabled="{Binding CanRerunFailedJobs}"/>
                                                    <MenuItem Header="Request Copilot review" Tag="{Binding}"
                                                              Click="PrRow_RequestCopilotReview_Click"
                                                              IsEnabled="{Binding CanRequestCopilotReview}"/>
                                                    <MenuItem Header="Move to later" Tag="{Binding}"
                                                              Click="PrRow_Hide_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Ellipse Width="10" Height="10"
                                                             Fill="{Binding CIState, Converter={StaticResource CIStateToBrush}}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="&#xE8BD;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11"
                                                               Foreground="#8B949E"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Visibility="{Binding HasUnresolvedReviewComments, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#3FB950" VerticalAlignment="Center" Margin="5,0,0,0" Visibility="{Binding ShowApprovedIcon, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="&#xE748;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="11"
                                                               Foreground="#D29922"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Visibility="{Binding ShowNoReviewerWarning, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Style="{StaticResource RepoText}">
                                                        <Run Text="{Binding Repository, Mode=OneWay}"/>
                                                        <Run Text="{Binding Number, StringFormat='#{0}', Mode=OneWay}"/>
                                                        <Run Text=" by "/>
                                                        <Run Text="{Binding Author, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource TitleText}" Text="{Binding Title}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Style="{StaticResource MetaText}"
                                                           Text="{Binding TimeAgo}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Separator after Hotfixes -->
                        <Border Height="1" Background="#21262D" Margin="0,4,0,8"/>
                    </StackPanel>

                    <!-- Section: Auto-Merge PRs -->
                    <StackPanel Visibility="{Binding AutoMergeCount, Converter={StaticResource NonZeroToVisibleConverter}}">
                        <Border MouseLeftButtonUp="AutoMergeHeader_Click" Cursor="Hand"
                                Background="Transparent" Margin="0,0,0,6">
                            <DockPanel>
                                <!-- Chevron -->
                                <TextBlock DockPanel.Dock="Left"
                                           Text="&#xE70D;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="10" Foreground="#6E7681"
                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding AutoMergeExpanded, 
                                            Converter={StaticResource BoolToAngleConverter}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons"
                                               FontSize="12" Foreground="#58A6FF"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E6EDF3"
                                               VerticalAlignment="Center">
                                        <Run Text="My Auto-Merge PRs "/>
                                        <Run Text="{Binding AutoMergeCount, StringFormat='({0})', Mode=OneWay}"
                                             Foreground="#8B949E"/>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <StackPanel Visibility="{Binding AutoMergeExpanded, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl ItemsSource="{Binding AutoMergePrs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PrRow}"
                                                MouseLeftButtonUp="PrItem_Click"
                                                ToolTip="{Binding PrTooltip}"
                                                Tag="{Binding}">
                                            <Border.ContextMenu>
                                                <ContextMenu Style="{StaticResource PrRowContextMenuStyle}">
                                                    <MenuItem Header="Copy PR URL" Tag="{Binding}"
                                                              Click="PrRow_CopyUrl_Click"/>
                                                    <MenuItem Header="Copy branch name" Tag="{Binding}"
                                                              Click="PrRow_CopyBranch_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Rerun failed jobs" Tag="{Binding}"
                                                              Click="PrRow_RerunFailedJobs_Click"
                                                              IsEnabled="{Binding CanRerunFailedJobs}"/>
                                                    <MenuItem Header="Request Copilot review" Tag="{Binding}"
                                                              Click="PrRow_RequestCopilotReview_Click"
                                                              IsEnabled="{Binding CanRequestCopilotReview}"/>
                                                    <MenuItem Header="Move to later" Tag="{Binding}"
                                                              Click="PrRow_Hide_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Ellipse Width="10" Height="10"
                                                             Fill="{Binding CIState, Converter={StaticResource CIStateToBrush}}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="&#xE8BD;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11"
                                                               Foreground="#8B949E"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Visibility="{Binding HasUnresolvedReviewComments, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#3FB950" VerticalAlignment="Center" Margin="5,0,0,0" Visibility="{Binding ShowApprovedIcon, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="&#xE748;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="11"
                                                               Foreground="#D29922"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Visibility="{Binding ShowNoReviewerWarning, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Style="{StaticResource RepoText}">
                                                        <Run Text="{Binding Repository, Mode=OneWay}"/>
                                                        <Run Text="{Binding Number, StringFormat='#{0}', Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource TitleText}" Text="{Binding Title}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Style="{StaticResource MetaText}"
                                                           Text="{Binding TimeAgo}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Separator after Auto-Merge -->
                        <Border Height="1" Background="#21262D" Margin="0,4,0,8"/>
                    </StackPanel>

                    <!-- Section: Review Requested -->
                    <StackPanel Visibility="{Binding ReviewCount, Converter={StaticResource NonZeroToVisibleConverter}}">
                        <Border MouseLeftButtonUp="ReviewHeader_Click" Cursor="Hand"
                                Background="Transparent" Margin="0,0,0,6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                           FontSize="10" Foreground="#6E7681" VerticalAlignment="Center"
                                           Margin="0,0,6,0" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding ReviewExpanded,
                                            Converter={StaticResource BoolToAngleConverter}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE7EE;" FontFamily="Segoe Fluent Icons"
                                               FontSize="12" Foreground="#D29922"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E6EDF3"
                                               VerticalAlignment="Center">
                                        <Run Text="Awaiting My Review "/>
                                        <Run Text="{Binding ReviewCount, StringFormat='({0})', Mode=OneWay}"
                                             Foreground="#8B949E"/>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <StackPanel Visibility="{Binding ReviewExpanded, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl ItemsSource="{Binding ReviewRequestedPrs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PrRow}"
                                                MouseLeftButtonUp="PrItem_Click"
                                                ToolTip="{Binding PrTooltip}"
                                                Tag="{Binding}">
                                            <Border.ContextMenu>
                                                <ContextMenu Style="{StaticResource PrRowContextMenuStyle}">
                                                    <MenuItem Header="Copy PR URL" Tag="{Binding}"
                                                              Click="PrRow_CopyUrl_Click"/>
                                                    <MenuItem Header="Copy branch name" Tag="{Binding}"
                                                              Click="PrRow_CopyBranch_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Rerun failed jobs" Tag="{Binding}"
                                                              Click="PrRow_RerunFailedJobs_Click"
                                                              IsEnabled="{Binding CanRerunFailedJobs}"/>
                                                    <MenuItem Header="Request Copilot review" Tag="{Binding}"
                                                              Click="PrRow_RequestCopilotReview_Click"
                                                              IsEnabled="{Binding CanRequestCopilotReview}"/>
                                                    <MenuItem Header="Move to later" Tag="{Binding}"
                                                              Click="PrRow_Hide_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Ellipse Width="10" Height="10"
                                                             Fill="{Binding CIState, Converter={StaticResource CIStateToBrush}}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="&#xE8BD;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11"
                                                               Foreground="#8B949E"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Visibility="{Binding HasUnresolvedReviewComments, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#3FB950" VerticalAlignment="Center" Margin="5,0,0,0" Visibility="{Binding ShowApprovedIcon, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Style="{StaticResource RepoText}">
                                                        <Run Text="{Binding Repository, Mode=OneWay}"/>
                                                        <Run Text="{Binding Number, StringFormat='#{0}', Mode=OneWay}"/>
                                                        <Run Text=" by "/>
                                                        <Run Text="{Binding Author, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource TitleText}" Text="{Binding Title}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Style="{StaticResource MetaText}"
                                                           Text="{Binding TimeAgo}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Separator after Review -->
                        <Border Height="1" Background="#21262D" Margin="0,4,0,8"/>
                    </StackPanel>

                    <!-- Section: My PRs (non-auto-merge, collapsed by default) -->
                    <StackPanel Visibility="{Binding MyPrsCount, Converter={StaticResource NonZeroToVisibleConverter}}">
                        <Border MouseLeftButtonUp="MyPrsHeader_Click" Cursor="Hand"
                                Background="Transparent" Margin="0,0,0,6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                           FontSize="10" Foreground="#6E7681" VerticalAlignment="Center"
                                           Margin="0,0,6,0" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding MyPrsExpanded,
                                            Converter={StaticResource BoolToAngleConverter}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe Fluent Icons"
                                               FontSize="12" Foreground="#8B949E"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#C9D1D9"
                                               VerticalAlignment="Center">
                                        <Run Text="My PRs "/>
                                        <Run Text="{Binding MyPrsCount, StringFormat='({0})', Mode=OneWay}"
                                             Foreground="#8B949E"/>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <StackPanel Visibility="{Binding MyPrsExpanded, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl ItemsSource="{Binding MyPrs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PrRow}"
                                                MouseLeftButtonUp="PrItem_Click"
                                                ToolTip="{Binding PrTooltip}"
                                                Tag="{Binding}">
                                            <Border.ContextMenu>
                                                <ContextMenu Style="{StaticResource PrRowContextMenuStyle}">
                                                    <MenuItem Header="Copy PR URL" Tag="{Binding}"
                                                              Click="PrRow_CopyUrl_Click"/>
                                                    <MenuItem Header="Copy branch name" Tag="{Binding}"
                                                              Click="PrRow_CopyBranch_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Rerun failed jobs" Tag="{Binding}"
                                                              Click="PrRow_RerunFailedJobs_Click"
                                                              IsEnabled="{Binding CanRerunFailedJobs}"/>
                                                    <MenuItem Header="Request Copilot review" Tag="{Binding}"
                                                              Click="PrRow_RequestCopilotReview_Click"
                                                              IsEnabled="{Binding CanRequestCopilotReview}"/>
                                                    <MenuItem Header="Move to later" Tag="{Binding}"
                                                              Click="PrRow_Hide_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- EffectiveCIState is grey for draft PRs -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Ellipse Width="10" Height="10"
                                                             Fill="{Binding EffectiveCIState, Converter={StaticResource CIStateToBrush}}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="&#xE8BD;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11"
                                                               Foreground="#8B949E"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Visibility="{Binding HasUnresolvedReviewComments, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#3FB950" VerticalAlignment="Center" Margin="5,0,0,0" Visibility="{Binding ShowApprovedIcon, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="&#xE748;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="11"
                                                               Foreground="#D29922"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Visibility="{Binding ShowNoReviewerWarning, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Style="{StaticResource RepoText}">
                                                        <Run Text="{Binding Repository, Mode=OneWay}"/>
                                                        <Run Text="{Binding Number, StringFormat='#{0}', Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource TitleText}" Text="{Binding Title}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Style="{StaticResource MetaText}"
                                                           Text="{Binding TimeAgo}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Separator after My PRs -->
                        <Border Height="1" Background="#21262D" Margin="0,4,0,8"/>
                    </StackPanel>

                    <!-- Section: Team Review Requests -->
                    <StackPanel Visibility="{Binding TeamReviewCount, Converter={StaticResource NonZeroToVisibleConverter}}">
                        <Border MouseLeftButtonUp="TeamReviewHeader_Click" Cursor="Hand"
                                Background="Transparent" Margin="0,0,0,6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                           FontSize="10" Foreground="#6E7681" VerticalAlignment="Center"
                                           Margin="0,0,6,0" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding TeamReviewExpanded,
                                            Converter={StaticResource BoolToAngleConverter}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE902;" FontFamily="Segoe Fluent Icons"
                                               FontSize="12" Foreground="#8B949E"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#C9D1D9"
                                               VerticalAlignment="Center">
                                        <Run Text="Team Review Requests "/>
                                        <Run Text="{Binding TeamReviewCount, StringFormat='({0})', Mode=OneWay}"
                                             Foreground="#8B949E"/>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <StackPanel Visibility="{Binding TeamReviewExpanded, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl ItemsSource="{Binding TeamReviewRequestedPrs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PrRow}"
                                                MouseLeftButtonUp="PrItem_Click"
                                                ToolTip="{Binding PrTooltip}"
                                                Tag="{Binding}">
                                            <Border.ContextMenu>
                                                <ContextMenu Style="{StaticResource PrRowContextMenuStyle}">
                                                    <MenuItem Header="Copy PR URL" Tag="{Binding}"
                                                              Click="PrRow_CopyUrl_Click"/>
                                                    <MenuItem Header="Copy branch name" Tag="{Binding}"
                                                              Click="PrRow_CopyBranch_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Rerun failed jobs" Tag="{Binding}"
                                                              Click="PrRow_RerunFailedJobs_Click"
                                                              IsEnabled="{Binding CanRerunFailedJobs}"/>
                                                    <MenuItem Header="Request Copilot review" Tag="{Binding}"
                                                              Click="PrRow_RequestCopilotReview_Click"
                                                              IsEnabled="{Binding CanRequestCopilotReview}"/>
                                                    <MenuItem Header="Move to later" Tag="{Binding}"
                                                              Click="PrRow_Hide_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Ellipse Width="10" Height="10"
                                                             Fill="{Binding CIState, Converter={StaticResource CIStateToBrush}}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="&#xE8BD;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11"
                                                               Foreground="#8B949E"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Visibility="{Binding HasUnresolvedReviewComments, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#3FB950" VerticalAlignment="Center" Margin="5,0,0,0" Visibility="{Binding ShowApprovedIcon, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Style="{StaticResource RepoText}">
                                                        <Run Text="{Binding Repository, Mode=OneWay}"/>
                                                        <Run Text="{Binding Number, StringFormat='#{0}', Mode=OneWay}"/>
                                                        <Run Text=" by "/>
                                                        <Run Text="{Binding Author, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource TitleText}" Text="{Binding Title}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Style="{StaticResource MetaText}"
                                                           Text="{Binding TimeAgo}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Separator after Team Review Requests -->
                        <Border Height="1" Background="#21262D" Margin="0,4,0,8"/>
                    </StackPanel>

                    <!-- Section: Later -->
                    <StackPanel Visibility="{Binding HiddenCount, Converter={StaticResource NonZeroToVisibleConverter}}">
                        <Border MouseLeftButtonUp="LaterHeader_Click" Cursor="Hand"
                                Background="Transparent" Margin="0,0,0,6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="&#xE70D;" FontFamily="Segoe Fluent Icons"
                                           FontSize="10" Foreground="#6E7681" VerticalAlignment="Center"
                                           Margin="0,0,6,0" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding LaterExpanded,
                                            Converter={StaticResource BoolToAngleConverter}}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE823;" FontFamily="Segoe Fluent Icons"
                                               FontSize="12" Foreground="#6E7681"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#6E7681"
                                               VerticalAlignment="Center">
                                        <Run Text="Later "/>
                                        <Run Text="{Binding HiddenCount, StringFormat='({0})', Mode=OneWay}"
                                             Foreground="#484F58"/>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <StackPanel Visibility="{Binding LaterExpanded, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl ItemsSource="{Binding HiddenPrs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PrRow}"
                                            MouseLeftButtonUp="PrItem_Click"
                                            ToolTip="{Binding PrTooltip}"
                                            Tag="{Binding}">
                                        <Border.ContextMenu>
                                            <ContextMenu Style="{StaticResource PrRowContextMenuStyle}">
                                                <MenuItem Header="Copy PR URL" Tag="{Binding}"
                                                          Click="PrRow_CopyUrl_Click"/>
                                                <MenuItem Header="Copy branch name" Tag="{Binding}"
                                                          Click="PrRow_CopyBranch_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Rerun failed jobs" Tag="{Binding}"
                                                          Click="PrRow_RerunFailedJobs_Click"
                                                          IsEnabled="{Binding CanRerunFailedJobs}"/>
                                                <MenuItem Header="Request Copilot review" Tag="{Binding}"
                                                          Click="PrRow_RequestCopilotReview_Click"
                                                          IsEnabled="{Binding CanRequestCopilotReview}"/>
                                                <MenuItem Header="Restore" Tag="{Binding}"
                                                          Click="PrRow_Restore_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <Ellipse Width="10" Height="10"
                                                         Fill="{Binding CIState, Converter={StaticResource CIStateToBrush}}"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="&#xE8BD;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="11"
                                                           Foreground="#8B949E"
                                                           VerticalAlignment="Center"
                                                           Margin="5,0,0,0"
                                                           Visibility="{Binding HasUnresolvedReviewComments, Converter={StaticResource BoolToVisibility}}"/>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#3FB950" VerticalAlignment="Center" Margin="5,0,0,0" Visibility="{Binding ShowApprovedIcon, Converter={StaticResource BoolToVisibility}}"/>
                                                <TextBlock Text="&#xE748;"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="11"
                                                           Foreground="#D29922"
                                                           VerticalAlignment="Center"
                                                           Margin="5,0,0,0"
                                                           Visibility="{Binding ShowNoReviewerWarning, Converter={StaticResource BoolToVisibility}}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Style="{StaticResource RepoText}">
                                                    <Run Text="{Binding Repository, Mode=OneWay}"/>
                                                    <Run Text="{Binding Number, StringFormat='#{0}', Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Style="{StaticResource TitleText}"
                                                           Text="{Binding Title}" Opacity="0.6"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource MetaText}" Text="{Binding TimeAgo}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding SnoozedUntilText}" FontSize="9" Foreground="#484F58" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#161B22" CornerRadius="0,0,8,8" Padding="12,6">
                <Grid>
                    <!-- Normal hint text, shown when no update is available -->
                    <TextBlock Visibility="{Binding UpdateNotAvailable, Converter={StaticResource BoolToVisibility}}"
                               FontSize="10" Foreground="#484F58" HorizontalAlignment="Center"
                               Text="Click a PR to open in GitHub &#183; Right-click tray icon for more"/>
                    <!-- Offline indicator, shown when the last poll failed -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Panel.ZIndex="2"
                                Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibility}}">
                        <Ellipse Width="7" Height="7" Fill="#F85149" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Offline &#x2014; retrying…" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Update available banner, shown when update is available -->
                    <Border Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}"
                            Cursor="Hand" MouseLeftButtonUp="UpdateBanner_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       Foreground="#3FB950"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock FontSize="10" Foreground="#3FB950"
                                       Text="{Binding LatestVersion, StringFormat='Update available: v{0}  &#x2014;  click to download'}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
