<Application x:Class="PrMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PrMonitor.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <conv:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter"/>
        <conv:NonZeroToVisibleConverter x:Key="NonZeroToVisibleConverter"/>
        <conv:BoolToAngleConverter x:Key="BoolToAngleConverter"/>
        <conv:CIStateToBrushConverter x:Key="CIStateToBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- PR row layout resources (updated by ApplyCompactMode) -->
        <Thickness x:Key="PrRowPadding">8,6,8,6</Thickness>
        <sys:Double x:Key="PrRowFontSize">12</sys:Double>
        <sys:Double x:Key="PrRowRepoFontSize">10</sys:Double>

        <!-- Material Symbols Rounded (bundled font) -->
        <FontFamily x:Key="MaterialSymbols">pack://application:,,,/Assets/Fonts/#Material Symbols Rounded</FontFamily>
        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MaterialSymbols}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Dark-themed tooltips to match the app's GitHub-dark palette -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
    </Application.Resources>
</Application>
