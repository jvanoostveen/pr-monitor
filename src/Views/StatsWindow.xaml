<Window x:Class="PrMonitor.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PR Monitor – Statistics"
        Width="460" Height="480"
        MinWidth="360" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#0D1117">

    <Window.Resources>

        <!-- ── Buttons ───────────────────────────────────────────────── -->
        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
            </Border>
        </ControlTemplate>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Table cell text styles ────────────────────────────────── -->
        <Style x:Key="HeaderCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="NumberCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas, monospace"/>
        </Style>

        <Style x:Key="AuthorNumberCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas, monospace"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisible"/>

        <!-- ── Chevron toggle button for inline breakdowns ────────────── -->
        <!-- (style kept for potential reuse; main usage is now inline ControlTemplate) -->

        <!-- ── Minimal overlay scrollbar (matches main window) ───────── -->
        <Style x:Key="MinimalScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3" Background="#555E69" Margin="1,3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalScrollBar" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent" Width="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Height="0" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MinimalScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Height="0" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayScrollViewer" TargetType="ScrollViewer">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Margin="{TemplateBinding Padding}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Stretch"
                                       Style="{StaticResource MinimalScrollBar}"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_VerticalScrollBar"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_VerticalScrollBar"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Margin="10" Padding="14" Background="#0D1117"
            BorderBrush="#30363D" BorderThickness="1" CornerRadius="8">
        <Grid Grid.IsSharedSizeScope="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title -->
                <RowDefinition Height="Auto"/>  <!-- Table header -->
                <RowDefinition Height="*"/>     <!-- Rows -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Statistics" FontSize="18" FontWeight="Bold" Foreground="#E6EDF3"/>
                <TextBlock FontSize="11" Foreground="#6E7681" Margin="0,3,0,0"
                           Text="Counted while PR Monitor is running."/>
            </StackPanel>

            <!-- Table header -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" SharedSizeGroup="MetricCol"/>
                    <ColumnDefinition Width="64" SharedSizeGroup="TodayCol"/>
                    <ColumnDefinition Width="64" SharedSizeGroup="WeekCol"/>
                    <ColumnDefinition Width="64" SharedSizeGroup="MonthCol"/>
                    <ColumnDefinition Width="64" SharedSizeGroup="TotalCol"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource HeaderCell}" Text="Metric"/>
                <TextBlock Grid.Column="1" Style="{StaticResource HeaderCell}" Text="Today"  HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="2" Style="{StaticResource HeaderCell}" Text="Week"   HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="3" Style="{StaticResource HeaderCell}" Text="Month"  HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="4" Style="{StaticResource HeaderCell}" Text="Total"  HorizontalAlignment="Right"/>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="#30363D"
                    VerticalAlignment="Bottom" Margin="0,0,0,-1"/>

            <!-- Rows -->
            <ScrollViewer Grid.Row="2" Style="{StaticResource OverlayScrollViewer}">
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="0,7" BorderBrush="#21262D" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" SharedSizeGroup="MetricCol"/>
                                            <ColumnDefinition Width="64" SharedSizeGroup="TodayCol"/>
                                            <ColumnDefinition Width="64" SharedSizeGroup="WeekCol"/>
                                            <ColumnDefinition Width="64" SharedSizeGroup="MonthCol"/>
                                            <ColumnDefinition Width="64" SharedSizeGroup="TotalCol"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Metric label: entire text+chevron is clickable when HasBreakdown -->
                                        <ToggleButton Grid.Column="0"
                                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                      OverridesDefaultStyle="True"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Label}"
                                                                   Foreground="#C9D1D9" FontSize="13"/>
                                                        <TextBlock x:Name="Chevron" Text="&#x203A;"
                                                                   Foreground="#6E7681" FontSize="13"
                                                                   Margin="5,0,0,0"
                                                                   Visibility="Collapsed"
                                                                   RenderTransformOrigin="0.5,0.5">
                                                            <TextBlock.RenderTransform>
                                                                <RotateTransform x:Name="Rot" Angle="0"/>
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding HasBreakdown}" Value="True">
                                                            <Setter TargetName="Chevron" Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="Rot"
                                                                                         Storyboard.TargetProperty="Angle"
                                                                                         To="90" Duration="0:0:0.15"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="Rot"
                                                                                         Storyboard.TargetProperty="Angle"
                                                                                         To="0" Duration="0:0:0.15"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <TextBlock Grid.Column="1" Style="{StaticResource NumberCell}" Text="{Binding Today}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource NumberCell}" Text="{Binding Week}"/>
                                        <TextBlock Grid.Column="3" Style="{StaticResource NumberCell}" Text="{Binding Month}"/>
                                        <TextBlock Grid.Column="4" Style="{StaticResource NumberCell}" Text="{Binding Total}"
                                                   FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                    </Grid>
                                    <!-- Per-author breakdown (toggle with chevron) -->
                                    <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisible}}"
                                                Margin="0,4,0,0">
                                        <ItemsControl ItemsSource="{Binding VisibleAuthorBreakdown}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                            <!-- Per-author breakdown: same SharedSizeGroups as outer rows, indent via Padding -->
                                            <Grid Margin="0,2">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{Binding DisplayName, StringFormat='Hide {0}'}"
                                                                  Click="HideReviewer_Click"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" SharedSizeGroup="MetricCol"/>
                                                    <ColumnDefinition Width="64" SharedSizeGroup="TodayCol"/>
                                                    <ColumnDefinition Width="64" SharedSizeGroup="WeekCol"/>
                                                    <ColumnDefinition Width="64" SharedSizeGroup="MonthCol"/>
                                                    <ColumnDefinition Width="64" SharedSizeGroup="TotalCol"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                           Padding="20,0,0,0"
                                                           Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Style="{StaticResource AuthorNumberCell}" Text="{Binding Today}"/>
                                                <TextBlock Grid.Column="2" Style="{StaticResource AuthorNumberCell}" Text="{Binding Week}"/>
                                                <TextBlock Grid.Column="3" Style="{StaticResource AuthorNumberCell}" Text="{Binding Month}"/>
                                                <TextBlock Grid.Column="4" Style="{StaticResource AuthorNumberCell}" Text="{Binding Total}"
                                                           FontWeight="SemiBold"/>
                                            </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- Toggle inactive reviewers link -->
                                        <Button Margin="20,3,0,2"
                                                HorizontalAlignment="Left"
                                                OverridesDefaultStyle="True"
                                                Cursor="Hand"
                                                Content="{Binding ToggleInactiveLabel}"
                                                Visibility="{Binding HasInactiveReviewers, Converter={StaticResource BoolToVisible}}"
                                                Click="ToggleShowAllReviewers_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Foreground" Value="#4493F8"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <ContentPresenter/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="#79C0FF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <TextBlock Grid.Row="3" Margin="0,6,0,0"
                       FontSize="11" Foreground="#6E7681"
                       Text="{Binding LastUpdated, StringFormat='Updated {0}'}"/>
        </Grid>
    </Border>
</Window>
