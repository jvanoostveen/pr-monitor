<Window x:Class="PrMonitor.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update changelog"
        Width="760"
        Height="580"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#0D1117">

    <Window.Resources>
        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
            </Border>
        </ControlTemplate>

        <Style x:Key="WindowButtonBase" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="34"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource WindowButtonBase}">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                    <Setter Property="BorderBrush" Value="#484F58"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#161B22"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                    <Setter Property="BorderBrush" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource WindowButtonBase}">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2EA043"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2EA043"/>
                    <Setter Property="BorderBrush" Value="#3FB950"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1F6F2D"/>
                    <Setter Property="BorderBrush" Value="#238636"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="12" Padding="18" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                <Border Height="1" Background="#21262D" Margin="0,0,0,14"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Open release page"
                            Margin="0,0,8,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="OpenReleasePage_Click"/>
                    <Button Content="Close"
                            Width="96"
                            Style="{StaticResource PrimaryButton}"
                            Click="Close_Click"
                            IsCancel="True"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="{Binding WindowTitle}"
                           Foreground="#E6EDF3"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Relevant entries from CHANGELOG.md"
                           Margin="0,6,0,0"
                           Foreground="#8B949E"
                           FontSize="12"/>
            </StackPanel>

            <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6">
                <TextBox Text="{Binding ContentText}"
                         Padding="14"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#C9D1D9"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"/>
            </Border>
        </DockPanel>
    </Border>
</Window>