<Window x:Class="PrMonitor.Views.FlakinessRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PR Monitor – Flakiness Rules"
        Width="540" Height="480"
        MinWidth="380" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#0D1117">

    <Window.Resources>

        <!-- ── CheckBox ──────────────────────────────────────────────── -->
        <Style TargetType="CheckBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box"
                                    Width="16" Height="16"
                                    Background="#161B22"
                                    BorderBrush="#484F58"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <Viewbox x:Name="CheckIcon" Width="9" Height="9"
                                         Visibility="Collapsed" Stretch="Uniform">
                                    <Canvas Width="12" Height="12">
                                        <Path Data="M 1,6 L 4.5,9.5 L 11,2"
                                              Stroke="White" StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#1F6FEB"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#388BFD"/>
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Buttons ───────────────────────────────────────────────── -->
        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
            </Border>
        </ControlTemplate>

        <Style x:Key="SettingsButtonBase" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Padding" Value="0,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource SettingsButtonBase}">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                    <Setter Property="BorderBrush" Value="#484F58"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#161B22"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                    <Setter Property="BorderBrush" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border Margin="12" Padding="20" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock DockPanel.Dock="Left"
                           Text="LEARNED FLAKINESS RULES"
                           Foreground="#8B949E"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="#6E7681"
                           FontSize="11"
                           Text="{Binding FlakinessRules.Count, StringFormat={}{0} rule(s)}"/>
            </DockPanel>

            <Border Grid.Row="0" BorderBrush="#30363D" BorderThickness="0,0,0,1"
                    Margin="0,0,0,0" VerticalAlignment="Bottom"/>

            <!-- Rules list / empty state -->
            <Grid Grid.Row="1" Margin="0,12,0,0">

                <!-- Empty state -->
                <TextBlock Foreground="#6E7681" FontSize="12" FontStyle="Italic"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Text="No rules yet. Rules are suggested by the AI after analyzing flaky failures."
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FlakinessRules.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Scrollable list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FlakinessRules.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding FlakinessRules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#21262D" BorderThickness="0,0,0,1"
                                        Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Enabled toggle -->
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0"/>

                                        <!-- Pattern + description -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Pattern}"
                                                       Foreground="#79C0FF"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="#8B949E"
                                                       FontSize="11"
                                                       Margin="0,2,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Delete button -->
                                        <Button Grid.Column="2"
                                                Content="&#x2715;"
                                                Width="26" Height="26"
                                                Margin="10,0,0,0"
                                                Padding="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource SecondaryButton}"
                                                FontSize="11"
                                                Tag="{Binding Id}"
                                                Click="DeleteRule_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Footer -->
            <TextBlock Grid.Row="2"
                       Foreground="#6E7681" FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       Text="Changes are applied when you save the Settings window."/>
        </Grid>
    </Border>
</Window>
