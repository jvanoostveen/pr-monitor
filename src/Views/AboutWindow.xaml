<Window x:Class="PrMonitor.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PR Monitor"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1117">

    <Window.Resources>

        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
            </Border>
        </ControlTemplate>

        <Style x:Key="SettingsButtonBase" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Padding" Value="0,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource SettingsButtonBase}">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                    <Setter Property="BorderBrush" Value="#484F58"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#161B22"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                    <Setter Property="BorderBrush" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SettingsButtonBase}">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2EA043"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2EA043"/>
                    <Setter Property="BorderBrush" Value="#3FB950"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1F6F2D"/>
                    <Setter Property="BorderBrush" Value="#238636"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border Margin="12" Padding="20" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8">
        <StackPanel>

            <!-- Logo + name + version -->
            <Image Width="256" Height="256" Margin="0,0,0,14"
                   HorizontalAlignment="Center"
                   Stretch="Uniform"
                   Source="/Assets/logo_256.png"/>

            <TextBlock Text="PR Monitor"
                       HorizontalAlignment="Center"
                       Foreground="#E6EDF3"
                       FontSize="18"
                       FontWeight="SemiBold"/>

            <TextBlock Text="{Binding VersionText}"
                       HorizontalAlignment="Center"
                       Foreground="#8B949E"
                       FontSize="12"
                       Margin="0,4,0,0"/>

            <!-- Divider -->
            <Border Height="1" Background="#21262D" Margin="0,16,0,16"/>

            <!-- Repository link -->
            <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="#C9D1D9">
                <Run Text="GitHub: "/>
                <Hyperlink NavigateUri="https://github.com/jvanoostveen/pr-monitor"
                           RequestNavigate="RepoLink_RequestNavigate"
                           Foreground="#58A6FF">
                    <Run Text="jvanoostveen/pr-monitor"/>
                </Hyperlink>
            </TextBlock>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Check for updates…"
                        Width="160" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="CheckForUpdates_Click"/>
                <Button Content="Close"
                        Width="90"
                        Style="{StaticResource PrimaryButton}"
                        Click="Close_Click"
                        IsCancel="True"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
