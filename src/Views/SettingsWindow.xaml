<Window x:Class="PrMonitor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PR Monitor – Settings"
        Width="560" MinHeight="340"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1117">

    <Window.Resources>

        <!-- ── TextBox ─────────────────────────────────────────────────── -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="CaretBrush" Value="#C9D1D9"/>
            <Setter Property="SelectionBrush" Value="#264F78"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#58A6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Buttons ─────────────────────────────────────────────────── -->
        <!--
            OverridesDefaultStyle removes WPF's ButtonChrome which adds a
            light-colored hover overlay regardless of our Background trigger.
            The ControlTemplate renders only a Border + ContentPresenter.
        -->
        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
            </Border>
        </ControlTemplate>

        <Style x:Key="SettingsButtonBase" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Padding" Value="0,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource SettingsButtonBase}">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                    <Setter Property="BorderBrush" Value="#484F58"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#161B22"/>
                    <Setter Property="Foreground" Value="#E6EDF3"/>
                    <Setter Property="BorderBrush" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SettingsButtonBase}">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2EA043"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2EA043"/>
                    <Setter Property="BorderBrush" Value="#3FB950"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1F6F2D"/>
                    <Setter Property="BorderBrush" Value="#238636"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── CheckBox ────────────────────────────────────────────────── -->
        <Style TargetType="CheckBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box"
                                    Width="16" Height="16"
                                    Background="#161B22"
                                    BorderBrush="#484F58"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <Viewbox x:Name="CheckIcon" Width="9" Height="9"
                                         Visibility="Collapsed" Stretch="Uniform">
                                    <Canvas Width="12" Height="12">
                                        <Path Data="M 1,6 L 4.5,9.5 L 11,2"
                                              Stroke="White" StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#1F6FEB"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#388BFD"/>
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ── RadioButton ─────────────────────────────────────── -->
        <Style TargetType="RadioButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Ring"
                                    Width="16" Height="16"
                                    Background="#161B22"
                                    BorderBrush="#484F58"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <Ellipse x:Name="Dot"
                                         Width="8" Height="8"
                                         Fill="White"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Background" Value="#1F6FEB"/>
                                <Setter TargetName="Ring" Property="BorderBrush" Value="#388BFD"/>
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ── Slider ──────────────────────────────────────────────────── -->
        <Style x:Key="SliderRepeatButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="4" Background="{TemplateBinding Background}" CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="Ellipse" Fill="#58A6FF" Stroke="#388BFD" StrokeThickness="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ellipse" Property="Fill" Value="#79C0FF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Ellipse" Property="Fill" Value="#388BFD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}" Background="#58A6FF"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}" Background="#21262D"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tab chrome ─────────────────────────────────────────────── -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="2,8,16,8">
                            <ContentPresenter ContentSource="Header"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" Background="Transparent" HorizontalAlignment="Left"/>
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

    </Window.Resources>

    <Border Margin="12" Padding="20" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0">

                <!-- ══ General tab ══════════════════════════════════════════ -->
                <TabItem Header="General">
                    <StackPanel Margin="0,20,0,0">

                        <!-- Organizations -->
                        <TextBlock Text="GitHub Organizations (one per line)"
                                   Foreground="#C9D1D9" FontSize="13" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource SettingsTextBox}"
                                 Text="{Binding OrganizationsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="110" VerticalScrollBarVisibility="Auto"/>

                        <!-- Polling interval -->
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Foreground="#C9D1D9" FontSize="13" Margin="0,0,0,8">
                                <Run Text="Polling interval: "/>
                                <Run Text="{Binding PollingIntervalSeconds, Mode=OneWay}"/>
                                <Run Text=" seconds"/>
                            </TextBlock>
                            <Slider Minimum="30" Maximum="600"
                                    TickFrequency="30" IsSnapToTickEnabled="True"
                                    Value="{Binding PollingIntervalSeconds}"/>
                        </StackPanel>

                        <!-- Auto-start -->
                        <CheckBox Margin="0,16,0,0"
                                  IsChecked="{Binding AutoStartWithWindows}"
                                  Content="Start with Windows"/>

                        <CheckBox Margin="0,8,0,0"
                                  IsChecked="{Binding CompactMode}"
                                  Content="Compact mode (smaller rows)"/>

                        <CheckBox Margin="0,8,0,0"
                                  IsChecked="{Binding VerboseLogging}"
                                  Content="Verbose logging"/>
                        <TextBlock Foreground="#6E7681" FontSize="11" Margin="24,2,0,0" TextWrapping="Wrap"
                                   Text="Enable to write informational log entries (window placement, poll lifecycle, etc.). Errors are always logged."/>

                        <!-- Auto-merge merge method -->
                        <TextBlock Text="AUTO-MERGE METHOD" Style="{StaticResource SectionLabel}" Margin="0,16,0,6"/>
                        <RadioButton Margin="0,0,0,6" IsChecked="{Binding AutoMergeMethodMerge}"   Content="Merge commit"/>
                        <RadioButton Margin="0,0,0,6" IsChecked="{Binding AutoMergeMethodSquash}"  Content="Squash and merge"/>
                        <RadioButton Margin="0,0,0,0" IsChecked="{Binding AutoMergeMethodRebase}"  Content="Rebase and merge"/>
                        <TextBlock Foreground="#6E7681" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Merge strategy used when enabling auto-merge from the PR context menu."/>

                    </StackPanel>
                </TabItem>

                <!-- ══ Sections tab ══════════════════════════════════════════ -->
                <TabItem Header="Sections">
                    <StackPanel Margin="0,20,0,0">

                        <TextBlock Text="REVIEW REQUESTS" Style="{StaticResource SectionLabel}"/>
                        <CheckBox IsChecked="{Binding ShowTeamReviewSection}"
                                  Content="Show team review requests as a separate section"/>
                        <TextBlock Foreground="#6E7681" FontSize="11" Margin="24,4,0,0" TextWrapping="Wrap"
                                   Text="When enabled, PRs requested from a team appear in a dedicated &#x2018;Team Review Requests&#x2019; section. When disabled, team review requests are not shown."/>
                        <CheckBox Margin="24,10,0,0"
                                  IsChecked="{Binding TeamReviewCountsForTrayIcon}"
                                  Content="Count team review requests in tray icon status"
                                  IsEnabled="{Binding ShowTeamReviewSection}"/>
                        <TextBlock Foreground="#6E7681" FontSize="11" Margin="48,4,0,0" TextWrapping="Wrap"
                                   IsEnabled="{Binding ShowTeamReviewSection}"
                                   Text="When enabled, team review requests contribute to the amber tray icon colour."/>

                    </StackPanel>
                </TabItem>

                <!-- ══ Hidden PRs tab ═══════════════════════════════════════ -->
                <TabItem Header="Hidden PRs">
                    <StackPanel Margin="0,20,0,0">

                        <TextBlock Text="MANUALLY HIDDEN PRS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Foreground="#6E7681" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"
                                   Text="PRs hidden via the Hide action are listed here. Remove one to show it again in the main window."/>

                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="8">
                            <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding HiddenPrs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,6">
                                                <Button DockPanel.Dock="Right"
                                                        Content="Remove"
                                                        Width="76"
                                                        Margin="8,0,0,0"
                                                        Tag="{Binding Key}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="HiddenPrRemove_Click"/>
                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="#C9D1D9"
                                                           FontFamily="Consolas"
                                                           Text="{Binding Key}"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                    </StackPanel>
                </TabItem>

                <!-- ══ Notifications tab ═════════════════════════════════════ -->
                <TabItem Header="Notifications">
                    <StackPanel Margin="0,20,0,0">

                        <!-- When to show -->
                        <TextBlock Text="WHEN TO SHOW" Style="{StaticResource SectionLabel}"/>
                        <RadioButton Margin="0,0,0,6" IsChecked="{Binding NotificationModeAlways}"          Content="Always"/>
                        <RadioButton Margin="0,0,0,6" IsChecked="{Binding NotificationModeWhenWindowClosed}" Content="Only when window is closed"/>
                        <RadioButton Margin="0,0,0,0" IsChecked="{Binding NotificationModeNever}"           Content="Never"/>

                        <!-- Per-type toggles (grayed out when Never) -->
                        <StackPanel Margin="0,16,0,0" IsEnabled="{Binding IndividualTogglesEnabled}">

                            <!-- CI group -->
                            <TextBlock Text="CI STATUS" Style="{StaticResource SectionLabel}"/>
                            <CheckBox Margin="0,0,0,10" IsChecked="{Binding NotifyCiFailed}"   Content="CI Failed"/>
                            <CheckBox Margin="0,0,0,10" IsChecked="{Binding NotifyCiPassed}"   Content="CI Passed (recovered from failure)"/>
                            <CheckBox Margin="0,0,0,0"  IsChecked="{Binding NotifyCiError}"    Content="CI Error"/>

                            <!-- Activity group -->
                            <TextBlock Text="ACTIVITY" Style="{StaticResource SectionLabel}" Margin="0,16,0,10"/>
                            <CheckBox Margin="0,0,0,10" IsChecked="{Binding NotifyReviewRequested}"  Content="Review Requested"/>
                            <CheckBox Margin="0,0,0,0"  IsChecked="{Binding NotifyPrMergedOrClosed}" Content="PR Merged / Closed"/>

                            <!-- Flakiness group -->
                            <TextBlock Text="FLAKINESS" Style="{StaticResource SectionLabel}" Margin="0,16,0,10"/>
                            <CheckBox Margin="0,0,0,10" IsChecked="{Binding NotifyFlakinessRerun}"        Content="Flaky CI — auto-rerun triggered"/>
                            <CheckBox Margin="0,0,0,0"  IsChecked="{Binding NotifyFlakinessRealFailure}"  Content="Real failure detected (not flaky)"/>

                            <!-- Other -->
                            <TextBlock Text="OTHER" Style="{StaticResource SectionLabel}" Margin="0,16,0,10"/>
                            <CheckBox Margin="0,0,0,0" IsChecked="{Binding NotifyStartupSummary}" Content="Summary on startup"/>
                            <CheckBox Margin="0,4,0,0"
                                      IsChecked="{Binding NotifyMentioned}"
                                      IsEnabled="{Binding IndividualTogglesEnabled}"
                                      Content="You were mentioned in a PR"/>

                        </StackPanel>

                    </StackPanel>
                </TabItem>

                <!-- ══ Flakiness tab ═════════════════════════════════════════ -->
                <TabItem Header="Flakiness">
                    <StackPanel Margin="0,20,0,0">

                        <!-- Enable toggle -->
                        <CheckBox IsChecked="{Binding FlakinessAnalysisEnabled}"
                                  Content="Enable flakiness analysis and auto-rerun"/>
                        <TextBlock Foreground="#6E7681" FontSize="11" Margin="24,4,0,12" TextWrapping="Wrap"
                                   Text="When enabled, CI failures on your own PRs are analyzed using the GitHub Models API (gpt-4o-mini) via your existing GitHub account. Flaky failures are automatically retried up to your configured maximum."/>

                        <CheckBox IsChecked="{Binding FlakinessAutoMergeOnly}"
                                  Content="Only analyze auto-merge PRs"
                                  Margin="0,0,0,6"/>
                        <TextBlock Foreground="#6E7681" FontSize="11" Margin="24,0,0,12" TextWrapping="Wrap"
                                   Text="When enabled, the AI flakiness analysis is only used for PRs in My Auto-Merge PRs."/>

                        <StackPanel Margin="24,0,0,12">
                            <TextBlock Foreground="#C9D1D9" FontSize="12" Margin="0,0,0,6"
                                   Text="Maximum automatic reruns"/>
                            <Slider Minimum="1" Maximum="10"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="{Binding FlakinessMaxReruns}"/>
                            <TextBlock Foreground="#8B949E" FontSize="11" Margin="0,4,0,0"
                                   Text="{Binding FlakinessMaxReruns, StringFormat={}{0} attempt(s)}"/>
                        </StackPanel>

                        <!-- Custom AI hints -->
                        <TextBlock Text="CUSTOM AI HINTS" Style="{StaticResource SectionLabel}"
                                   Margin="0,8,0,6"/>
                        <TextBlock Foreground="#6E7681" FontSize="11" Margin="0,0,0,6" TextWrapping="Wrap"
                                   Text="Free-text context injected into the AI system prompt. Use this to describe project-specific CI characteristics — for example which test suites are inherently flaky, or known infrastructure instabilities."/>
                        <TextBox AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="72"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding FlakinessCustomHints, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0D1117" Foreground="#C9D1D9"
                                 BorderBrush="#30363D" BorderThickness="1"
                                 Padding="6" FontSize="12"
                                 Margin="0,0,0,12"/>

                        <Separator Background="#30363D" Margin="0,4,0,16"/>

                        <!-- Rules heading + manage button -->
                        <TextBlock Text="LEARNED FLAKINESS RULES" Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,6"/>
                        <DockPanel Margin="0,0,0,0">
                            <TextBlock DockPanel.Dock="Left"
                                       VerticalAlignment="Center"
                                       Foreground="#6E7681" FontSize="12"
                                       Text="{Binding FlakinessRules.Count, StringFormat={}{0} rule(s) learned}"/>
                            <Button DockPanel.Dock="Right"
                                    Content="Manage rules…"
                                    Width="120"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="ManageFlakinessRules_Click"/>
                        </DockPanel>

                    </StackPanel>
                </TabItem>

            </TabControl>

            <!-- Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Width="92" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click"
                        IsCancel="True"/>
                <Button Content="Save" Width="92"
                        Style="{StaticResource PrimaryButton}"
                        Click="Save_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
