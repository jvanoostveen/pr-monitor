<Window x:Class="PrBot.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PR Monitor – Settings"
        Width="400" Height="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1117">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Organizations -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="GitHub Organizations (one per line)"
                       Foreground="#C9D1D9" FontSize="13" Margin="0,0,0,4"/>
            <TextBox Text="{Binding OrganizationsText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     Background="#161B22" Foreground="#C9D1D9"
                     BorderBrush="#30363D" Padding="6,4"
                     FontSize="12" FontFamily="Consolas"
                     Height="100" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- Polling interval -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock Foreground="#C9D1D9" FontSize="13" Margin="0,0,0,4">
                <Run Text="Polling interval: "/>
                <Run Text="{Binding PollingIntervalSeconds, Mode=OneWay}"/>
                <Run Text=" seconds"/>
            </TextBlock>
            <Slider Minimum="30" Maximum="600"
                    TickFrequency="30" IsSnapToTickEnabled="True"
                    Value="{Binding PollingIntervalSeconds}"
                    Foreground="#58A6FF"/>
        </StackPanel>

        <!-- Auto-start -->
        <CheckBox Grid.Row="3" Margin="0,16,0,0"
                  IsChecked="{Binding AutoStartWithWindows}"
                  Foreground="#C9D1D9" FontSize="13"
                  Content="Start with Windows"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="#21262D" Foreground="#C9D1D9" BorderBrush="#30363D"
                    Padding="0,6"/>
            <Button Content="Save" Width="80"
                    Click="Save_Click"
                    Background="#238636" Foreground="White" BorderBrush="#2EA043"
                    Padding="0,6" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
