<Window x:Class="PrMonitor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PR Monitor – Settings"
        Width="420" MinHeight="340"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1117">

    <Window.Resources>
        <Style x:Key="SettingsButtonBase" TargetType="Button">
            <Setter Property="Padding" Value="0,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#58A6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource SettingsButtonBase}">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#484F58"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#161B22"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SettingsButtonBase}">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2EA043"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2EA043"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#3FB950"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1F6F2D"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#238636"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab header style: underline indicator for selected tab -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="2,8,16,8">
                            <ContentPresenter ContentSource="Header"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl: remove default chrome, draw only tab-strip separator -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="0,0,0,0">
                                <TabPanel IsItemsHost="True" Background="Transparent" HorizontalAlignment="Left"/>
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="NotifyCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Margin="12" Padding="20" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0">

                <!-- ══ General tab ══════════════════════════════════════════ -->
                <TabItem Header="General">
                    <StackPanel Margin="0,20,0,0">

                        <!-- Organizations -->
                        <TextBlock Text="GitHub Organizations (one per line)"
                                   Foreground="#C9D1D9" FontSize="13" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource SettingsTextBox}"
                                 Text="{Binding OrganizationsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="110" VerticalScrollBarVisibility="Auto"/>

                        <!-- Polling interval -->
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Foreground="#C9D1D9" FontSize="13" Margin="0,0,0,6">
                                <Run Text="Polling interval: "/>
                                <Run Text="{Binding PollingIntervalSeconds, Mode=OneWay}"/>
                                <Run Text=" seconds"/>
                            </TextBlock>
                            <Slider Minimum="30" Maximum="600"
                                    TickFrequency="30" IsSnapToTickEnabled="True"
                                    Value="{Binding PollingIntervalSeconds}"
                                    Foreground="#58A6FF"/>
                        </StackPanel>

                        <!-- Auto-start -->
                        <CheckBox Margin="0,16,0,0"
                                  IsChecked="{Binding AutoStartWithWindows}"
                                  Foreground="#C9D1D9" FontSize="13"
                                  VerticalContentAlignment="Center"
                                  Content="Start with Windows"/>

                    </StackPanel>
                </TabItem>

                <!-- ══ Notifications tab ═════════════════════════════════════ -->
                <TabItem Header="Notifications">
                    <StackPanel Margin="0,20,0,0">

                        <!-- CI group -->
                        <TextBlock Text="CI STATUS" Style="{StaticResource SectionLabel}"/>
                        <CheckBox Style="{StaticResource NotifyCheckBox}"
                                  IsChecked="{Binding NotifyCiFailed}"
                                  Content="CI Failed"/>
                        <CheckBox Style="{StaticResource NotifyCheckBox}"
                                  IsChecked="{Binding NotifyCiPassed}"
                                  Content="CI Passed (recovered from failure)"/>
                        <CheckBox Style="{StaticResource NotifyCheckBox}"
                                  IsChecked="{Binding NotifyCiError}"
                                  Content="CI Error"/>

                        <!-- Activity group -->
                        <TextBlock Text="ACTIVITY" Style="{StaticResource SectionLabel}" Margin="0,12,0,8"/>
                        <CheckBox Style="{StaticResource NotifyCheckBox}"
                                  IsChecked="{Binding NotifyReviewRequested}"
                                  Content="Review Requested"/>
                        <CheckBox Style="{StaticResource NotifyCheckBox}"
                                  IsChecked="{Binding NotifyPrMergedOrClosed}"
                                  Content="PR Merged / Closed"/>

                    </StackPanel>
                </TabItem>

            </TabControl>

            <!-- Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Width="92" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click"
                        IsCancel="True"/>
                <Button Content="Save" Width="92"
                        Style="{StaticResource PrimaryButton}"
                        Click="Save_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

